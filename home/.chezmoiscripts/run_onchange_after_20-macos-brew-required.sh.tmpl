{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail

brewfiles=(
  "{{ .chezmoi.sourceDir }}/../packages/Brewfile.required"
  "{{ .chezmoi.sourceDir }}/../packages/Brewfile.macos.required"
)

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew is required before macOS package sync. Run bootstrap/macos.sh first." >&2
  exit 1
fi

for brewfile in "${brewfiles[@]}"; do
  brew bundle check --file="$brewfile" || brew bundle install --file="$brewfile"
done
{{- end }}
