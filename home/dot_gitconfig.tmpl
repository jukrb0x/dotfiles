{{- $isDarwin := eq .chezmoi.os "darwin" -}}
{{- $isLinux := eq .chezmoi.os "linux" -}}
{{- $isWindows := eq .chezmoi.os "windows" -}}
[user]
	useConfigOnly = true
[https "https://github.com"]
	# proxy = socks5://127.0.0.1:6153
[http "https://github.com"]
	# proxy = socks5://127.0.0.1:6153
[commit]
	gpgsign = false
[gpg]
	program = gpg
[tag]
	forceSignAnnotated = true
[core]
	editor = {{ if $isWindows }}~/.local/bin/lvim.bat{{ else }}lvim{{ end }}
	quotepath = false
	longpaths = true
	autocrlf = input
	trustctime = false
	excludesfile = ~/.gitignore_global
	attributesfile = ~/.attributes_global
	ignorecase = true
	filemode = {{ if $isWindows }}false{{ else }}true{{ end }}
	untrackedcache = true
[init]
	defaultBranch = main
[alias]
	a = add
	ap = add -p
	amc = am --continue
	b = branch
	bm = branch --merged
	bnm = branch --no-merged
	c = clone
	ca = commit --amend
	cane = commit --amend --no-edit
	cf = commit --fixup
	cm = commit --message
	co = checkout
	cob = checkout -b
	com = checkout main
	cp = cherry-pick
	d = diff
	dc = diff --cached
	dom = diff origin/main
	fo = fetch origin
	fu = "!git log -n 16 --pretty=format:'%h %s' --no-merges | fzf | cut -c -7 | xargs -o git commit --fixup"
	g = grep --line-number
	mbhom = merge-base HEAD origin/main
	mff = merge --ff-only
	ol = log --pretty=oneline
	l = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	p = push
	pf = push --force-with-lease
	prb = pull --rebase
	r = restore
	ra = rebase --abort
	rc = rebase --continue
	ri = rebase --interactive
	rl = reflog
	riom = rebase --interactive origin/main
	rpo = remote prune origin
	s = status -sb
	sh = "!git log -n 16 --pretty=format:'%h %s' --no-merges | fzf | cut -c -7 | xargs -o git show"
	ss = commit --message snapshot --no-gpg-sign
	su = submodule update
	wd = diff --patience --word-diff
[pull]
	rebase = false
[diff "text"]
	textconv = cat
[mergetool]
	keepBackup = false
	writeToTemp = true
[lfs]
	concurrenttransfers = 64
	fetchrecentrefsdays = 0
	pruneoffsetdays = 0
	dialtimeout = 3
	tlstimeout = 3
[rebase]
	backend = merge
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[safe]
	directory = *
[http]
	postBuffer = 655360000
[lfs "transfer"]
	maxretries = 1
	maxretrydelay = 2
[merge "lfs-text"]
	driver = git lfs merge-driver --ancestor %O --current %A --other %B --marker-size %L --output %A --program 'git merge-file --stdout --marker-size=%%L %%A %%O %%B >%%D'
[include]
	path = ~/.gitconfig.local
{{ if $isLinux }}
[credential "https://github.com"]
	helper = 
	helper = !/home/linuxbrew/.linuxbrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/home/linuxbrew/.linuxbrew/bin/gh auth git-credential
{{ end}}
